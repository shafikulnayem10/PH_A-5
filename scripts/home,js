let allIssues = [];
let currentTab = "all";
const API_BASE = "https://phi-lab-server.vercel.app/api/v1/lab";

// handletab with style change

function handleTab(tab) {
  currentTab = tab;

  const allBtn = document.getElementById("tab-all");
  const openBtn = document.getElementById("tab-open");
  const closedBtn = document.getElementById("tab-closed");

  allBtn.classList.remove("border-b-2","border-violet-600","text-violet-600");
  openBtn.classList.remove("border-b-2","border-violet-600","text-violet-600");
  closedBtn.classList.remove("border-b-2","border-violet-600","text-violet-600");

 
  if (tab === "all") {
    allBtn.classList.add("border-b-2","border-violet-600","text-violet-600");
  } 
  else if (tab === "open") {
    openBtn.classList.add("border-b-2","border-violet-600","text-violet-600");
  } 
  else if (tab === "closed") {
    closedBtn.classList.add("border-b-2","border-violet-600","text-violet-600");
  }
}
// ─── Spinner Helper Function 
const manageSpinner = (show) => {
  const spinner   = document.getElementById("spinner");
  const container = document.getElementById("issues-container");
  const empty     = document.getElementById("empty-state");

  if (show === true) {
    spinner.classList.remove("hidden");
    container.classList.add("hidden");
    empty.classList.add("hidden");
  } else {
    spinner.classList.add("hidden");
    container.classList.remove("hidden");
  }
};
// load all issues
const loadAllIssues = async () => {
  manageSpinner(true);
  try {
    
    const res  = await fetch(`${API_BASE}/issues`);
    const data = await res.json();
    allIssues  = data.data ;
    
    displayIssues(allIssues);
    document.getElementById("filter-label").textContent =
      ` ${allIssues.length} issues`;
  } catch (err) {
    manageSpinner(false);
    console.log("Failed to fetch issues:", err);
    showEmpty("Failed to load issues. Please check your connection.");
   
    
  }
};
// display issues in UI
const displayIssues = (issues) => {

  const container = document.getElementById("issues-container");
  const empty = document.getElementById("empty-state");
  manageSpinner(false);

  container.innerHTML = "";

  if (issues.length === 0) {
    container.classList.add("hidden");
    empty.classList.remove("hidden");
  } else {
    empty.classList.add("hidden");
    container.classList.remove("hidden");

    issues.forEach((issue) => {
      const card = createIssueCard(issue);
      container.appendChild(card);
    });
  }

};
// Create Issue Card 
const createIssueCard = (issue) => {

  // check status
let isOpen;

if (issue.status && issue.status.toLowerCase() === "open") {
  isOpen = true;
} else {
  isOpen = false;
}

  // top border color
  let topBorder;
  if (isOpen == true) {
    topBorder = "border-t-4 border-t-green-500";
  } else {
    topBorder = "border-t-4 border-t-purple-500";
  }

  // created date
  let createdAt = "N/A";
  if (issue.created_at === null || issue.created_at === undefined) {
    const date = new Date(issue.created_at);
    createdAt = date.toLocaleDateString("en-US", {
      year: "numeric",
      month: "short",
      day: "numeric"
    });
  }

  // status badge
  let statusBadge;
  if (isOpen == true) {
    statusBadge = `
      <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-semibold bg-green-100 text-green-700 border border-green-200">
        <i class="fa-solid fa-circle-dot text-[10px]"></i>Open
      </span>
    `;
  } else {
    statusBadge = `
      <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-semibold bg-purple-100 text-purple-700 border border-purple-200">
        <i class="fa-solid fa-circle-check text-[10px]"></i>Closed
      </span>
    `;
  }

  // label badge
  let labelBadge = "";
  if (issue.label && issue.label.trim() !== "") {
    labelBadge = `
      <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs border border-base-300 text-gray-500">
        ${issue.label}
      </span>
    `;
  }

  // category badge
  let categoryBadge = "";
  if (issue.category && issue.category.trim() !== "") {
    categoryBadge = `
      <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs bg-base-200 text-gray-600">
        ${issue.category}
      </span>
    `;
  }

  const priorityBadge = getPriorityBadge(issue.priority);

  // create card
  const card = document.createElement("div");

  card.className =
    `bg-base-100 rounded-2xl shadow-sm ${topBorder} p-5 flex flex-col gap-3 cursor-pointer hover:-translate-y-1 hover:shadow-md transition-all duration-150`;

  card.innerHTML = `
    <div class="flex items-start justify-between gap-2">
      ${statusBadge}
      <span class="text-xs text-gray-400">#${issue.id || ""}</span>
    </div>

    <h3 class="font-bold text-base leading-snug hover:text-violet-600 transition-colors">
      ${issue.title || "Untitled Issue"}
    </h3>

    <p class="text-gray-500 text-sm leading-relaxed overflow-hidden"
       style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;">
      ${issue.description || "No description provided."}
    </p>

    <div class="flex flex-wrap gap-1 mt-auto">
      ${labelBadge}
      ${categoryBadge}
      ${priorityBadge}
    </div>

    <div class="border-t border-base-200 pt-3 flex items-center justify-between text-xs text-gray-400">
      <span class="flex items-center gap-1">
        <i class="fa-solid fa-user text-gray-300"></i>
        <span class="font-medium text-gray-600">${issue.author || "Unknown"}</span>
      </span>
      <span>${createdAt}</span>
    </div>
  `;

 

  return card;
};


//  Priority Badge 
const getPriorityBadge = (priority) => {

  if (priority === null || priority === undefined) {
    return "";
  }

  const p = priority.toLowerCase();
  let cls = "bg-gray-100 text-gray-600";

  if (p === "high" ) {
    cls = "bg-red-100 text-red-700";
  } 
  else if (p === "medium") {
    cls = "bg-yellow-100 text-yellow-700";
  } 
  else if (p === "low") {
    cls = "bg-green-100 text-green-700";
  }

  return `
    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold ${cls}">
      ${priority}
    </span>
  `;
};

const showEmpty = (msg = "No issues found") => {
  const empty = document.getElementById("empty-state");
  empty.querySelector("h3").textContent = msg;
  empty.classList.remove("hidden");
  document.getElementById("issues-container").classList.add("hidden");
};



loadAllIssues();
